generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  PARTNER
  ADMIN
}

enum PartnerStatus {
  PENDING
  APPROVED
  REJECTED
}

model Users {
  id            String        @id
  email         String        @unique
  role          UserRole      @default(USER)
  partnerStatus PartnerStatus @default(PENDING)
  name          String?
  createdAt     DateTime      @default(now())

  portfolios    Portfolios[]
  quoteRequests QuoteRequests[]
  quotes        Quotes[]
}

model Portfolios {
  id          String   @id @default(cuid())
  companyId   String
  title       String
  description String?
  imageUrls   String[]
  tags        String[]
  createdAt   DateTime @default(now())

  company Users @relation(fields: [companyId], references: [id])
}

model QuoteRequests {
  id           String   @id @default(cuid())
  userId       String
  propertyType String
  areaSize     Int
  budget       Int
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())

  user   Users   @relation(fields: [userId], references: [id])
  quotes Quotes[]
}

model Quotes {
  id         String   @id @default(cuid())
  requestId  String
  companyId  String
  totalPrice Int
  details    Json
  status     String   @default("SENT")
  createdAt  DateTime @default(now())

  request QuoteRequests @relation(fields: [requestId], references: [id])
  company Users         @relation(fields: [companyId], references: [id])
}

model AuditLogs {
  id         String   @id @default(cuid())
  actorId    String?
  entityType String
  entityId   String
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())
}
